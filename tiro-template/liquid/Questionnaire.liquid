<div>
  <h3>{{ Questionnaire.title }}</h3>
  <p>{{ Questionnaire.description }}</p>

  <p>
    <strong>Status:</strong> {{ Questionnaire.status }} ·
    <strong>Version:</strong> {{ Questionnaire.version }} ·
    <strong>URL:</strong> <code>{{ Questionnaire.url }}</code>
  </p>

  <h4>Items (walked from Liquid)</h4>
  <ul>
  {% for item in Questionnaire.item %}
    <li>
      <strong>{{ item.linkId }}</strong>
      <em>({{ item.type }})</em>
      — {{ item.text }}
      {% if item.item %}
      <ul>
      {% for sub in item.item %}
        <li>
          <code>{{ sub.linkId }}</code>
          <em>({{ sub.type }})</em>
          — {{ sub.text }}
          {% if sub.required = true %} <span style="color:#a00">[required]</span>{% endif %}
          {% if sub.answerValueSet.exists() %} → answers from <code>{{ sub.answerValueSet }}</code>{% endif %}
        </li>
      {% endfor %}
      </ul>
      {% endif %}
    </li>
  {% endfor %}
  </ul>

  <h4>Raw JSON (custom rendering test)</h4>
  <pre>{{ Questionnaire | json }}</pre>
</div>
